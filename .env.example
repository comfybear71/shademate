# Stripe keys — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe webhook signing secret — from https://dashboard.stripe.com/webhooks
# (or `stripe listen --forward-to localhost:3000/api/webhook` for local dev)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL of the site (no trailing slash). Used for checkout redirects + SEO.
# Locally: http://localhost:3000 — in production: https://shademate.xyz
NEXT_PUBLIC_SITE_URL=http://localhost:3000
