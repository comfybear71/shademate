# Stripe keys — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe webhook signing secret — from https://dashboard.stripe.com/webhooks
# (or `stripe listen --forward-to localhost:3000/api/webhook` for local dev)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Neon Postgres connection string. On Vercel, the Neon integration
# injects this automatically when you connect the database to the project.
# Stores orders + drives the launch-special "first 100 orders" counter.
DATABASE_URL=postgres://user:password@host/dbname

# Order notification emails via Resend (https://resend.com — free tier).
# Sign up with the email you want order alerts sent to, create an API
# key, and set both of these. Leave unset to skip emails (orders are
# still stored in the database and visible in Stripe).
RESEND_API_KEY=re_xxx
ORDER_NOTIFICATIONS_EMAIL=you@example.com

# Base URL of the site (no trailing slash). Used for checkout redirects + SEO.
# Locally: http://localhost:3000 — in production: https://shademate.xyz
NEXT_PUBLIC_SITE_URL=http://localhost:3000
